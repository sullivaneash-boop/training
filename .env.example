# Serverless only — never prefix with VITE_ (stays off the client bundle)
# Local: copy to .env.local and run `vercel dev`
# Vercel: Project Settings → Environment Variables

DEEPSEEK_API_KEY=sk-your-key-here

# Better Auth (server)
BETTER_AUTH_SECRET=generate-a-32-plus-char-secret
BETTER_AUTH_URL=http://localhost:3000

# Neon Postgres
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Optional comma-separated origins if frontend differs from API origin
# BETTER_AUTH_TRUSTED_ORIGINS=https://tempo.example.com,https://preview-tempo.vercel.app

# Optional: lock out new signups (1 = true)
# BETTER_AUTH_DISABLE_SIGNUP=0

# App login (protects /api/deepseek). Never commit the real password.
# Legacy fallback while migrating to Better Auth.
APP_PASSWORD=choose-a-strong-password-here

# Optional: separate secret for session cookies (defaults to APP_PASSWORD)
# AUTH_SECRET=random-long-string
